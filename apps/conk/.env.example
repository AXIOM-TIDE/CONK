# CONK Environment Variables
# Copy to .env.local and fill in values

# Sui Network: 'testnet' or 'mainnet'
VITE_SUI_NETWORK=testnet

# Shinami gas sponsorship API key
# Get from: shinami.com
VITE_SHINAMI_KEY=

# CONK Move package ID (after deployment)
# Deploy with: sui client publish protocol/sources/ --gas-budget 100000000
VITE_CONK_PACKAGE_ID=

# Relay pool contract address (after deployment)
VITE_RELAY_POOL_ADDRESS=

# Treasury address (Axiom Tide LLC)
# DO NOT CHANGE — this is the deployed treasury
VITE_TREASURY_ADDRESS=0x1d67c64a405aaca736e5a1c45e7251e37a634e5c32b15cb875ee83e4cd6ec204
